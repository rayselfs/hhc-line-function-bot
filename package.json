{
  "name": "hhc-line-function-bot",
  "version": "0.1.0",
  "private": false,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "lint": "eslint .",
    "format": "prettier --write .",
    "eval:router": "tsx src/tools/eval-router.ts",
    "check:notion": "tsx src/tools/check-notion-service-schedule.ts",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "@azure/identity": "^4.13.0",
    "@line/bot-sdk": "^10.1.1",
    "@microsoft/microsoft-graph-client": "^3.0.7",
    "@notionhq/client": "^5.1.0",
    "fastify": "^5.6.2",
    "redis": "^6.1.0",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@types/node": "^24.0.0",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.7.4",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.50.1",
    "vitest": "^4.0.16"
  },
  "engines": {
    "node": ">=24 <25"
  },
  "packageManager": "pnpm@11.7.0"
}
