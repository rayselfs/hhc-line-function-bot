{
  "name": "hhc-line-function-bot",
  "version": "0.1.0",
  "private": false,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "lint": "eslint .",
    "format": "prettier --write .",
    "eval:admin": "tsx src/tools/eval-admin-actions.ts",
    "eval:agent": "tsx src/tools/eval-agent-planner.ts",
    "eval:agent:live": "tsx src/tools/eval-agent-planner-live.ts",
    "eval:kernel": "tsx src/tools/eval-kernel.ts",
    "eval:kernel:integration": "tsx src/tools/eval-kernel-integration.ts",
    "eval:retrieval-product": "vitest run src/__tests__/retrieval-product-evals.test.ts",
    "catalog:sync": "tsx src/tools/sync-catalog.ts",
    "attachment-scan:run": "node dist/tools/run-attachment-scan-job.js",
    "config:validate": "tsx src/tools/check-profile-config.ts",
    "smoke:webhook": "tsx src/tools/smoke-webhook.ts",
    "check:notion": "tsx src/tools/check-notion-service-schedule.ts",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "@azure/identity": "^4.13.0",
    "@azure/storage-queue": "^12.31.0",
    "@line/bot-sdk": "^10.1.1",
    "@microsoft/microsoft-graph-client": "^3.0.7",
    "@notionhq/client": "^5.1.0",
    "fastify": "^5.6.2",
    "pg": "^8.22.0",
    "redis": "^6.1.0",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@types/node": "^24.0.0",
    "@types/pg": "^8.20.0",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.7.4",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.50.1",
    "vitest": "^4.0.16"
  },
  "engines": {
    "node": ">=24 <25"
  },
  "packageManager": "pnpm@11.7.0"
}
