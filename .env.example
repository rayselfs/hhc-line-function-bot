SERVICE_NAME=hhc-line-function-bot
OBSERVABILITY_HMAC_KEY=replace-with-at-least-32-random-characters
HOST=0.0.0.0
PORT=3000
TIME_ZONE=Asia/Taipei
HEALTH_PATH=/healthz
READY_PATH=/readyz
MAX_BODY_BYTES=262144
MAX_ATTACHMENT_BYTES=26214400
LINE_CONTENT_DOWNLOAD_TIMEOUT_MS=30000
EXTERNAL_RESOURCE_DOWNLOAD_TIMEOUT_MS=15000
EXTERNAL_RESOURCE_MAX_REDIRECTS=3

# The app loads the non-secret profile file from PROFILE_CONFIG_PATH.
# Do not set legacy BOT_PROFILES_JSON or BOT_PROFILES_BASE64_JSON.
PROFILE_CONFIG_PATH=./config/profiles.json
LINE_HELPER_CHANNEL_SECRET=PLACEHOLDER_LINE_HELPER_CHANNEL_SECRET
LINE_HELPER_CHANNEL_ACCESS_TOKEN=PLACEHOLDER_LINE_HELPER_CHANNEL_ACCESS_TOKEN
LINE_HELPER_ADMIN_USER_ID=PLACEHOLDER_LINE_HELPER_ADMIN_USER_ID

LLM_PROVIDER=ollama
LLM_FALLBACK_PROVIDER=ollama
OLLAMA_BASE_URL=http://PLACEHOLDER_OLLAMA_HOST:11434
OLLAMA_MODEL=qwen3:4b-instruct
OLLAMA_EMBEDDING_MODEL=bge-m3
EMBEDDING_OLLAMA_BASE_URL=
EMBEDDING_BATCH_SIZE=16
EMBEDDING_TIMEOUT_MS=30000
EMBEDDING_KEEP_ALIVE=1m
OLLAMA_TIMEOUT_MS=8000

DEEPSEEK_API_KEY=PLACEHOLDER_DEEPSEEK_API_KEY
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_TIMEOUT_MS=8000
LLM_CONTEXT_WINDOW_TOKENS=272000
LLM_RUNTIME_CONTEXT_BUDGET_TOKENS=2000
LLM_CONTEXT_COMPRESSION_THRESHOLD_RATIO=0.75
LLM_GENERAL_MAX_OUTPUT_TOKENS=160
LLM_ROUTE_MAX_OUTPUT_TOKENS=256

# Public Wikimedia API: include a bot name and operator contact URL or email.
WIKIMEDIA_USER_AGENT=HHCLineBot/1.0 (https://alive.org.tw/contact)
WIKIPEDIA_TIMEOUT_MS=8000
# Optional internal SearXNG endpoint for sheet-music-not-found fallback.
SEARXNG_BASE_URL=
SEARXNG_TIMEOUT_MS=8000

REDIS_URL=redis://PLACEHOLDER_REDIS_HOST:6379
REDIS_KEY_PREFIX=hhc-line-function-bot
REGISTRATION_INVITE_CODE_TTL_MINUTES=60
CONFIRMATION_TTL_MINUTES=5

DATABASE_URL=postgres://PLACEHOLDER_USER:PLACEHOLDER_PASSWORD@PLACEHOLDER_HOST:5432/PLACEHOLDER_DATABASE
DATABASE_SSL=true

RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=20
LAST_ERRORS_MAX_ENTRIES=20

GRAPH_TENANT_ID=PLACEHOLDER_TENANT_ID
GRAPH_CLIENT_ID=PLACEHOLDER_CLIENT_ID
GRAPH_CLIENT_SECRET=PLACEHOLDER_CLIENT_SECRET
GRAPH_DRIVE_ID=PLACEHOLDER_DRIVE_ID
GRAPH_PPT_FOLDER_ITEM_ID=PLACEHOLDER_FOLDER_ITEM_ID
GRAPH_POP_SHEET_DRIVE_ID=PLACEHOLDER_POP_SHEET_DRIVE_ID
GRAPH_POP_SHEET_FOLDER_ITEM_ID=PLACEHOLDER_POP_SHEET_FOLDER_ITEM_ID
GRAPH_HYMN_SHEET_FOLDER_ITEM_ID=PLACEHOLDER_HYMN_SHEET_FOLDER_ITEM_ID
GRAPH_XIAOHA_DOCUMENT_FOLDER_ITEM_ID=PLACEHOLDER_XIAOHA_DOCUMENT_FOLDER_ITEM_ID
GRAPH_XIAOHA_IMAGE_FOLDER_ITEM_ID=PLACEHOLDER_XIAOHA_IMAGE_FOLDER_ITEM_ID
GRAPH_XIAOHA_OTHER_FOLDER_ITEM_ID=PLACEHOLDER_XIAOHA_OTHER_FOLDER_ITEM_ID
GRAPH_WEEKLY_REPORT_AUDIO_FOLDER_ITEM_ID=PLACEHOLDER_WEEKLY_REPORT_AUDIO_FOLDER_ITEM_ID
GRAPH_LINK_TYPE=view
GRAPH_LINK_SCOPE=anonymous
SHEET_MUSIC_ALLOWED_EXTENSIONS=pdf,jpg,jpeg,png

# Optional HTTP virus scanner. If unset, attachment publishing fails closed.
VIRUS_SCAN_ENDPOINT=
VIRUS_SCAN_API_KEY=
VIRUS_SCAN_TIMEOUT_MS=8000
CLAMAV_HOST=
CLAMAV_PORT=3310
CLAMAV_TIMEOUT_MS=15000

NOTION_TOKEN=PLACEHOLDER_NOTION_TOKEN
NOTION_SERVICE_DATABASE_ID=PLACEHOLDER_DATABASE_ID
NOTION_DATE_PROPERTY=PLACEHOLDER_DATE_PROPERTY
NOTION_MEETING_PROPERTY=PLACEHOLDER_MEETING_PROPERTY
NOTION_ROLE_PROPERTY=PLACEHOLDER_ROLE_PROPERTY
NOTION_PERSON_PROPERTY=PLACEHOLDER_PERSON_PROPERTY
