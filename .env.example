SERVICE_NAME=hhc-line-function-bot
HOST=0.0.0.0
PORT=3000
TIME_ZONE=Asia/Taipei
HEALTH_PATH=/healthz
READY_PATH=/readyz
MAX_BODY_BYTES=262144

# Use placeholders only. Keep real LINE tokens/secrets in ACA secrets or local .env.
BOT_PROFILES_JSON=[{"name":"helper","webhookPath":"/api/line/webhook/helper","channelSecret":"PLACEHOLDER_LINE_CHANNEL_SECRET","channelAccessToken":"PLACEHOLDER_LINE_CHANNEL_ACCESS_TOKEN","allowDirectUser":true,"allowRooms":false,"allowedMessageTypes":["text"],"groupRequireWakeWord":true,"wakeKeywords":["小哈"],"acceptMention":true,"enabledFunctions":["find_ppt_slides","query_service_schedule","find_pop_sheet_music","save_schedule_memory","query_schedule_memory"],"adminUserId":"PLACEHOLDER_SUPERADMIN_LINE_USER_ID","adminDirectOnly":true,"directAccessPolicy":"managed","groupAccessPolicy":"managed","registration":{"enabled":true},"smallTalk":{"mode":"llm","maxChars":80,"personaPrompt":"你像一位成熟、溫和、懂生活的基督徒朋友，能自然理解教會生活，也懂一般日常生活。"},"generalAgent":{"enabled":true,"conversationWindowSeconds":60},"llmProvider":"ollama","allowedProviders":["ollama","deepseek"],"providerPolicy":{"function_routing":{"primary":"ollama"},"admin_routing":{"primary":"ollama"},"memory_routing":{"primary":"ollama"},"smart_talk":{"primary":"deepseek","fallback":"ollama"},"general_agent":{"primary":"deepseek","fallback":"ollama"},"context_compression":{"primary":"deepseek"}},"allowSubscriptionProviders":false},{"name":"main","webhookPath":"/api/line/webhook/main","channelSecret":"PLACEHOLDER_LINE_CHANNEL_SECRET","channelAccessToken":"PLACEHOLDER_LINE_CHANNEL_ACCESS_TOKEN","allowDirectUser":true,"allowRooms":false,"allowedMessageTypes":["text"],"groupRequireWakeWord":false,"wakeKeywords":["小哈"],"acceptMention":true,"enabledFunctions":["query_service_schedule"],"adminUserId":"PLACEHOLDER_SUPERADMIN_LINE_USER_ID","adminDirectOnly":true,"directAccessPolicy":"public","groupAccessPolicy":"blocked","registration":{"enabled":false},"llmProvider":"ollama","allowedProviders":["ollama"],"allowSubscriptionProviders":false}]

# Profile JSON also supports:
# - "smallTalk":{"mode":"llm","maxChars":80,"personaPrompt":"..."}
# - "generalAgent":{"enabled":true,"conversationWindowSeconds":60}
# - "longRunningJobs":{"enabled":true,"inlineReplyTimeoutMs":8000,"resultTtlMinutes":10}
# - "llmProvider":"ollama" or "deepseek"
# - "allowedProviders":["ollama","deepseek"] for internal helper profiles that may use the DeepSeek API
# - "providerPolicy":{"function_routing":{"primary":"ollama"},"smart_talk":{"primary":"deepseek","fallback":"ollama"},...}

LLM_PROVIDER=ollama
LLM_FALLBACK_PROVIDER=ollama
OLLAMA_BASE_URL=http://PLACEHOLDER_OLLAMA_HOST:11434
OLLAMA_MODEL=qwen3:4b-instruct
OLLAMA_TIMEOUT_MS=8000
KEYWORD_FALLBACK_ENABLED=true

# Optional DeepSeek API provider. Keep the real key in ACA secrets or local .env only.
DEEPSEEK_API_KEY=PLACEHOLDER_DEEPSEEK_API_KEY
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_TIMEOUT_MS=8000
LLM_CONTEXT_WINDOW_TOKENS=272000
LLM_RUNTIME_CONTEXT_BUDGET_TOKENS=2000
LLM_CONTEXT_COMPRESSION_THRESHOLD_RATIO=0.75
LLM_GENERAL_MAX_OUTPUT_TOKENS=160
LLM_ROUTE_MAX_OUTPUT_TOKENS=256

# Required when any profile has registration.enabled=true. Also used for sessions/cache/error/rate-limit state.
REDIS_URL=redis://PLACEHOLDER_REDIS_HOST:6379
REDIS_KEY_PREFIX=hhc-line-function-bot
REGISTRATION_INVITE_CODE_TTL_MINUTES=60
CONFIRMATION_TTL_MINUTES=5

# Required when any profile has registration.enabled=true.
DATABASE_URL=postgres://PLACEHOLDER_USER:PLACEHOLDER_PASSWORD@PLACEHOLDER_HOST:5432/PLACEHOLDER_DATABASE
DATABASE_SSL=true

RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=20
LAST_ERRORS_MAX_ENTRIES=20

GRAPH_TENANT_ID=PLACEHOLDER_TENANT_ID
GRAPH_CLIENT_ID=PLACEHOLDER_CLIENT_ID
GRAPH_CLIENT_SECRET=PLACEHOLDER_CLIENT_SECRET
GRAPH_DRIVE_ID=PLACEHOLDER_DRIVE_ID
GRAPH_PPT_FOLDER_ITEM_ID=PLACEHOLDER_FOLDER_ITEM_ID
GRAPH_SHEET_MUSIC_FOLDER_ITEM_ID=PLACEHOLDER_SHEET_MUSIC_FOLDER_ITEM_ID
GRAPH_SHEET_MUSIC_FOLDER_PATH=PLACEHOLDER_SHEET_MUSIC_FOLDER_PATH
GRAPH_LINK_TYPE=view
GRAPH_LINK_SCOPE=anonymous
PPT_ALLOWED_EXTENSIONS=ppt,pptx,pdf
PPT_DEFAULT_INCLUDE_PDF=false
SHEET_MUSIC_ALLOWED_EXTENSIONS=pdf,jpg,jpeg
SHEET_MUSIC_DEFAULT_RECURSIVE=true

NOTION_TOKEN=PLACEHOLDER_NOTION_TOKEN
NOTION_SERVICE_DATABASE_ID=PLACEHOLDER_DATABASE_ID
NOTION_DATE_PROPERTY=PLACEHOLDER_DATE_PROPERTY
NOTION_MEETING_PROPERTY=PLACEHOLDER_MEETING_PROPERTY
NOTION_ROLE_PROPERTY=PLACEHOLDER_ROLE_PROPERTY
NOTION_PERSON_PROPERTY=PLACEHOLDER_PERSON_PROPERTY
